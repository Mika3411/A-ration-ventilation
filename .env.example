CONTACT_TO=<recipient_email>
CONTACT_FROM=<sender_email_optional>
SMTP_HOST=<smtp_host>
SMTP_PORT=<smtp_port>
SMTP_USER=<smtp_username>
SMTP_PASS=<smtp_password>
DATABASE_URL=<postgres_connection_string>
DATABASE_SSL=auto
DATABASE_CA_CERT=<postgres_ca_certificate_optional>
AUTH_SECRET=<random_auth_secret>
ADMIN_USERNAME=<admin_username>
ADMIN_PASSWORD=<admin_password>
ADMIN_SESSION_SECRET=<random_admin_session_secret>

SITE_URL=<public_site_url>
STRIPE_SECRET_KEY=<stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<stripe_webhook_secret>
STRIPE_AUTOMATIC_TAX=<true_or_false>
